{
  "name": "__NAME__",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --env-file=.env node_modules/@minecms/server/dist/index.js",
    "start": "tsx --env-file=.env node_modules/@minecms/server/dist/index.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d"
  },
  "dependencies": {
    "@minecms/core": "alpha",
    "@minecms/sdk": "alpha",
    "@minecms/server": "alpha",
    "@minecms/studio": "alpha",
    "@minecms/ui": "alpha"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.6"
  }
}
