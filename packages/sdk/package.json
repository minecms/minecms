{
  "name": "@minecms/sdk",
  "version": "0.1.0-alpha.1",
  "description": "Типизированный клиент MineCMS — потребляет REST-API сервера и выводит типы из defineSchema через @minecms/core.",
  "keywords": [
    "minecms",
    "cms",
    "headless-cms",
    "sdk",
    "client",
    "typescript"
  ],
  "license": "Apache-2.0",
  "homepage": "https://minecms.ru",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minecms/minecms.git",
    "directory": "minecms/packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/minecms/minecms/issues"
  },
  "author": "MineCMS Team <hello@minecms.ru>",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "tag": "alpha",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@minecms/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "vitest": "catalog:"
  }
}
