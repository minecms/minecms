{
  "name": "@minecms/ui",
  "version": "0.1.0-alpha.2",
  "description": "Дизайн-система MineCMS — токены (oklch), Tailwind v4 preset и React-примитивы для Studio.",
  "keywords": [
    "minecms",
    "ui",
    "design-system",
    "react",
    "tailwindcss",
    "shadcn"
  ],
  "license": "Apache-2.0",
  "homepage": "https://minecms.ru",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minecms/minecms.git",
    "directory": "minecms/packages/ui"
  },
  "bugs": {
    "url": "https://github.com/minecms/minecms/issues"
  },
  "author": "MineCMS Team <hello@minecms.ru>",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./icons": {
      "types": "./src/icons.ts",
      "import": "./src/icons.ts"
    },
    "./styles.css": "./src/styles/index.css",
    "./tokens.css": "./src/styles/tokens.css"
  },
  "publishConfig": {
    "access": "public",
    "tag": "alpha",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./icons": {
        "types": "./dist/icons.d.ts",
        "import": "./dist/icons.js"
      },
      "./styles.css": "./dist/styles.css",
      "./tokens.css": "./dist/tokens.css"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json && cp src/styles/index.css dist/styles.css && cp src/styles/tokens.css dist/tokens.css",
    "typecheck": "tsc --noEmit",
    "test": "tsx scripts/check-stories.mts && vitest run --passWithNoTests",
    "storybook": "storybook dev -p 6006 --no-open",
    "storybook:build": "storybook build",
    "storybook:scaffold": "tsx scripts/scaffold-stories.mts",
    "storybook:check": "tsx scripts/check-stories.mts",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-themes": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "catalog:",
    "react-dom": "catalog:",
    "storybook": "^10.3.6",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "vite": "^8.0.10",
    "vitest": "catalog:"
  }
}
