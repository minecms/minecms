# MineCMS server — пример переменных окружения.
# Скопируй в .env и подставь реальные значения. На пустой машине достаточно
# DATABASE_DRIVER=mysql + DATABASE_URL — остальные подхватятся дефолтами.

# Сетевой порт сервера (по умолчанию 3333).
PORT=3333

# Драйвер БД: "mysql" или "postgres". На свежей установке default — mysql.
DATABASE_DRIVER=mysql

# Подключение к БД одной строкой URL.
# MySQL:    mysql://user:password@127.0.0.1:3306/minecms
# Postgres: postgres://user:password@127.0.0.1:5432/minecms
DATABASE_URL=mysql://minecms:minecms@127.0.0.1:3306/minecms

# Секрет для подписи сессионных cookie. Минимум 32 байта случайных данных.
# Сгенерировать: `openssl rand -hex 32` или `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
SESSION_SECRET=replace_me_with_openssl_rand_hex_32_output

# Уровень логирования pino: trace | debug | info | warn | error | fatal | silent.
LOG_LEVEL=info

# Окружение: development | production | test.
NODE_ENV=development
