{
  "name": "@minecms/server",
  "version": "0.1.0-alpha.1",
  "description": "MineCMS backend — Fastify v5 + tRPC v11 + Drizzle (MySQL/PostgreSQL) + signed-cookie сессии. Запускает headless API поверх схем, описанных через @minecms/core.",
  "keywords": [
    "minecms",
    "cms",
    "headless-cms",
    "server",
    "fastify",
    "trpc",
    "drizzle"
  ],
  "license": "Apache-2.0",
  "homepage": "https://minecms.ru",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minecms/minecms.git",
    "directory": "minecms/apps/server"
  },
  "bugs": {
    "url": "https://github.com/minecms/minecms/issues"
  },
  "author": "MineCMS Team <hello@minecms.ru>",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "import": "./src/server.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "tag": "alpha",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
      "minecms-server": "./dist/index.js"
    },
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./server": {
        "types": "./dist/server.d.ts",
        "import": "./dist/server.js"
      }
    }
  },
  "files": [
    "dist",
    "migrations",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate:mysql": "drizzle-kit generate --config=drizzle.config.mysql.ts",
    "db:generate:postgres": "drizzle-kit generate --config=drizzle.config.postgres.ts",
    "db:migrate:mysql": "tsx scripts/migrate.ts mysql",
    "db:migrate:postgres": "tsx scripts/migrate.ts postgres",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@minecms/core": "workspace:*",
    "@node-rs/argon2": "^2.0.2",
    "@trpc/server": "^11.17.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "image-size": "^2.0.2",
    "mysql2": "^3.22.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "tsup": "catalog:",
    "tsx": "^4.21.0",
    "vitest": "catalog:"
  }
}
